# ConfiguraciÃ³n de Adelinemagica â€” copia este archivo a `.env` y ajÃºstalo.
# Todas las variables usan el prefijo ADELINE_.

# Clave de administraciÃ³n (panel de Adelinemagica). Si se deja vacÃ­a, el
# servidor genera una al iniciar y la muestra en la consola.
ADELINE_ADMIN_TOKEN=

# PayPal â€” pega tu client-id (live o sandbox) para activar los botones de pago
# integrados. El handle de PayPal.Me alimenta el pago manual de respaldo.
ADELINE_PAYPAL_CLIENT_ID=
ADELINE_PAYPAL_ME_HANDLE=adelinemagica

# Precios autoritativos (el servidor nunca confÃ­a en el importe del cliente).
ADELINE_PRICE_MXN=100
ADELINE_PRICE_PEN=20
# PayPal no liquida en PEN: el plan en soles se cobra como este importe en USD.
ADELINE_PRICE_PEN_AS_USD=6

# Parametros video legacy (el flujo activo usa Google Meet via Google Calendar).
ADELINE_VIDEO_BASE_URL=https://meet.google.com
ADELINE_VIDEO_ROOM_PREFIX=Adelinemagica

# Entorno
ADELINE_DEBUG=true
ADELINE_DATABASE_URL=sqlite:///./adelinetarot.db

# Hosts permitidos (cabecera Host). En local con acceso desde el telÃ©fono usa
# "*"; en producciÃ³n fija tu dominio, p. ej. ADELINE_ALLOWED_HOSTS=adelinemagica.com
ADELINE_ALLOWED_HOSTS=localhost,127.0.0.1,adelinemagica.com,www.adelinemagica.com,adelinetarot2.onrender.com,*.onrender.com

# CORS (origenes permitidos para frontend separado del backend)
ADELINE_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://adelinemagica.com,https://www.adelinemagica.com,https://adelinetarot2.onrender.com

# Google Analytics Measurement Protocol (server-side; ne jamais mettre l'API secret dans le HTML)
ADELINE_GA_MEASUREMENT_ID=G-D4FYXHDVSL
ADELINE_GA_API_SECRET=
ADELINE_GA_MEASUREMENT_PROTOCOL_DEBUG=false

# SMTP (si activado en backend)
ADELINE_SMTP_HOST=
ADELINE_SMTP_PORT=587
ADELINE_SMTP_USER=
ADELINE_SMTP_PASSWORD=
ADELINE_SMTP_FROM=
ADELINE_SMTP_USE_TLS=true
ADELINE_SMTP_USE_SSL=false
ADELINE_MAIL_REPLY_TO=
ADELINE_NOTIFY_TO=garaizaoregel@gmail.com

# Resend (si migracion API implementada en backend)
ADELINE_RESEND_API_KEY=
ADELINE_RESEND_FROM=

# Fuseau horaire utilise pour les rendez-vous auto apres paiement Stripe direct
ADELINE_DIRECT_SCHEDULE_TIMEZONE=America/Lima

# Google Calendar/Meet (recommandé): creation de citas + invitation + lien Meet
ADELINE_GOOGLE_CALENDAR_ENABLED=false
ADELINE_GOOGLE_CALENDAR_ID=primary
# JSON du service account Google (inline) ou chemin absolu vers le fichier JSON
ADELINE_GOOGLE_CALENDAR_CREDENTIALS_JSON=
ADELINE_GOOGLE_CALENDAR_SEND_UPDATES=all
# Optionnel (Google Workspace + DWD): email utilisateur a deleguer
ADELINE_GOOGLE_CALENDAR_DELEGATE_USER=
ADELINE_GOOGLE_CALENDAR_DEFAULT_STATUS=tentative

